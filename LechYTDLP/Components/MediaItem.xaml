<UserControl x:Class="LechYTDLP.Components.MediaItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:controls="using:CommunityToolkit.WinUI.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:LechYTDLP.Components"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Button x:Name="QueueMediaItem"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}"
            Click="Click"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch">

        <Grid ColumnSpacing="12"
              Padding="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <!-- Resim -->
                <ColumnDefinition Width="*" />
                <!-- Metinler (Kalan yer) -->
            </Grid.ColumnDefinitions>

            <!-- Resim Alanı: Sabit Boyutlandırma -->
            <Border CornerRadius="{StaticResource ControlCornerRadius}"
                    Height="100"
                    Width="177"
                    MaxWidth="180"
                    MinWidth="170"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Image x:Name="QueueMediaItemThumbnail"
                       Height="100"
                       Width="177"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MaxWidth="180"
                       MinWidth="100" />
            </Border>

            <!-- Metin Alanı -->
            <Grid Grid.Column="1"
                  RowSpacing="4"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Stretch"
                  >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           x:Name="QueueMediaItemTitle"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           TextWrapping="NoWrap" />

                <!-- Uploader -->
                <RichTextBlock Grid.Row="1"
                               x:Name="QueueMediaItemUploaderAndSavingTo"
                               Style="{ThemeResource BodyRichTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               TextWrapping="NoWrap" />

                <Grid VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical"
                                Grid.Column="1"
                                Spacing="4">
                        <!--Metadata-->
                        <TextBlock  x:Name="QueueMediaItemMetadata"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"
                                    TextWrapping="NoWrap" />

                        <!-- Status -->
                        <TextBlock x:Name="QueueMediaItemStatus"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   TextWrapping="NoWrap" />
                    </StackPanel>

                    <!--Redownload: For failed downloads-->
                    <Button x:Name="QueueMediaItemRetryButton"
                            Style="{ThemeResource ButtonRevealStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Grid.Column="2"
                            Click="Click">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <SymbolIcon Symbol="Download" />
                            <TextBlock x:Uid="Retry" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Button>
</UserControl>