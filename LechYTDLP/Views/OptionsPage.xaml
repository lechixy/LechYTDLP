<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="LechYTDLP.Views.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:LechYTDLP.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <!--  These styles can be referenced to create a consistent SettingsPage layout  -->
        <!--  Spacing between cards  -->
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <!--  Style (inc. the correct spacing) of a section header  -->
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin"
                        Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}"
                        Margin="36,40"
                        Orientation="Vertical">

                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                </StackPanel.ChildrenTransitions>

                <TextBlock x:Uid="Options"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />

                <!--File-->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="File" />


                <controls:SettingsExpander x:Name="FileNameSettingsExpander"
                                           x:Uid="FileNameSettingsExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE8AC;}">
                    <controls:SettingsExpander.Items>

                        <controls:SettingsCard Header="@melih_abc123.mp4"
                                               x:Name="FileNamePreviewSettingsCard"
                                               x:Uid="FileNamePreviewSettingsCard">
                            <HyperlinkButton x:Name="FileNameSettingsHyperLink" />
                        </controls:SettingsCard>

                        <controls:SettingsCard ContentAlignment="Vertical"
                                               HorizontalContentAlignment="Stretch">
                            <TextBox x:Name="FileNameTextBox"
                                     PlaceholderText="Add tokens"
                                     TextChanged="TextChanged">
                            </TextBox>
                        </controls:SettingsCard>

                        <controls:SettingsCard HorizontalContentAlignment="Stretch"
                                               x:Name="FileNameActionsSettingsCard">
                            <controls:SettingsCard.Content>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <DropDownButton x:Uid="AddPlaceholders"
                                                    Click="Click"
                                                    Grid.Column="0">
                                        <DropDownButton.Flyout>
                                            <MenuFlyout Placement="Bottom"
                                                        x:Name="FileNameTemplatePlaceholdersMenuFlyout">
                                            </MenuFlyout>
                                        </DropDownButton.Flyout>
                                    </DropDownButton>
                                    <Button Click="Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            x:Uid="SaveButton"
                                            x:Name="FileNameTemplateSaveButton"
                                            Grid.Column="1" />
                                </Grid>
                            </controls:SettingsCard.Content>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>


                <controls:SettingsCard x:Name="SaveToSettingsCard"
                                       x:Uid="SaveToSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SaveToTextBox"
                                 x:Uid="SaveToTextBox"
                                 MaxWidth="300"
                                 Grid.Column="0"
                                 TextChanged="TextChanged" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                x:Name="SaveToButton"
                                Click="Click">
                            <SymbolIcon Symbol="OpenFile" />
                        </Button>
                    </Grid>
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="ForceOverwritesSetting"
                                       x:Name="ForceOverwritesSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE929;}">
                    <ToggleSwitch x:Name="ForceOverwritesSwitch"
                                  Toggled="SwitchToggled" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="SaveLogOfEachDownloadSetting"
                                       x:Name="SaveLogOfEachDownload"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8FF;}">
                    <ToggleSwitch x:Name="SaveLogOfEachDownloadSwitch"
                                  Toggled="SwitchToggled" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="EmbedThumbnailSetting"
                                       x:Name="EmbedThumbnailSetting"
                                       IsEnabled="False"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8B9;}">
                    <ToggleSwitch x:Name="EmbedThumbnailSettingSwitch"
                                  Toggled="SwitchToggled" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="EmbedSubsSetting"
                                       IsEnabled="False"
                                       x:Name="EmbedSubsSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7F0;}">
                    <ToggleSwitch x:Name="EmbedSubsSettingSwitch"
                                  Toggled="SwitchToggled" />
                </controls:SettingsCard>

                <!--Downloads-->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="Downloads" />

                <controls:SettingsCard x:Uid="ConcurrentFragmentsSetting"
                                       x:Name="ConcurrentFragmentsSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7BC;}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ConcurrentFragmentsSettingSlider"
                                ValueChanged="ValueChanged"
                                Maximum="25"
                                Minimum="1"
                                Grid.Column="0"
                                StepFrequency="1"
                                SnapsTo="StepValues" />
                        <!--<TextBlock x:Name="ConcurrentFragmentsSettingText"
                                   Text="1"
                                   Grid.Column="1"
                                   VerticalAlignment="Stretch" />-->
                    </Grid>
                </controls:SettingsCard>

                <!--Account-->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="Account" />
                <!--<controls:HeaderedContentControl Header="Account" Margin="0,0,0,4">
                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Sometimes requests need to be sent with cookie (to verify you are not a bot), this sections covers it."
                               TextWrapping="Wrap" />
                </controls:HeaderedContentControl>-->

                <controls:SettingsCard x:Name="CookiesSettingsCard"
                                       x:Uid="CookiesSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8BC;}">
                    <controls:SettingsCard.Description>
                        <HyperlinkButton x:Name="CookiesFileHyperLink"
                                         x:Uid="CookiesFileHyperLink" />
                    </controls:SettingsCard.Description>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CookiesFileTextBox"
                                 MaxWidth="300"
                                 Grid.Column="0"
                                 x:Uid="CookiesFileTextBox"
                                 TextChanged="TextChanged" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                x:Name="PickCookiesFileButton"
                                Click="Click">
                            <SymbolIcon Symbol="OpenFile" />
                        </Button>
                    </Grid>
                </controls:SettingsCard>

                <InfoBar x:Uid="AccountCookieNotice"
                         IsOpen="True"
                         IsClosable="False"
                         Margin="0,0,0,4"
                         Severity="Warning" />

                <!--Other-->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="Other" />

                <controls:SettingsCard x:Name="CustomParamsSetting"
                                       x:Uid="CustomParamsSetting"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE710;}">
                    <TextBox x:Name="CustomParamsTextBox"
                             MaxWidth="300"
                             x:Uid="CustomParamsTextBox"
                             TextChanged="TextChanged" />
                </controls:SettingsCard>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>