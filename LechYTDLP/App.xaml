<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="LechYTDLP.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:LechYTDLP">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Other app resources here -->
            <!-- Video Dialog Style -->
            <Style BasedOn="{StaticResource ResourceKey=DefaultContentDialogStyle}" x:Key="PlayerDialogStyle" TargetType="ContentDialog">
                <Setter Property="Padding"
                        Value="0" />
                <Setter Property="Margin"
                        Value="0" />
                <Setter Property="CornerRadius"
                        Value="0" />
            </Style>
            
            <local:LogTagToBrushConverter x:Key="LogTagToBrushConverter" />
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
